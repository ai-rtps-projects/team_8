0 0 0 rg
BT 1 0 0 1 36 544 Tm /F4 8 Tf 12 TL (  `\).join\(''\);) Tj T* (}) Tj T*  T* (function addFromDashboard\(id, name, price\) {) Tj T* (  cart.push\({ id, name, price }\);) Tj T* (  appendMessage\(`Added ${name} to your cart! Type checkout when ready.`, 'bot'\);) Tj T* (}) Tj T*  T* (function appendMessage\(text, sender\) {) Tj T* (  const win = document.getElementById\('chatWindow'\);) Tj T* (  const div = document.createElement\('div'\);) Tj T* (  div.className = `message ${sender === 'bot' ? 'bot-message' : 'user-message'}`;) Tj T* (  const now = new Date\(\).toLocaleTimeString\([], {hour:'2-digit', minute:'2-digit'}\);) Tj T* (  div.innerHTML = `) Tj T* (    <div class="message-content"><p>${text}</p></div>) Tj T* (    <div class="message-time">${now}</div>) Tj T* (  `;) Tj T* (  win.appendChild\(div\);) Tj T* (  win.scrollTop = win.scrollHeight;) Tj T* (}) Tj T*  T* (async function sendMessage\(e\) {) Tj T* (  e.preventDefault\(\);) Tj T* (  const input = document.getElementById\('userInput'\);) Tj T* (  const text = input.value.trim\(\);) Tj T* (  if \(!text\) return;) Tj T* (  appendMessage\(text, 'user'\);) Tj T* (  input.value = '';) Tj T*  T* (  // Show typing indicator) Tj T* (  const tmpl = document.getElementById\('typingIndicator'\);) Tj T* (  const typing = tmpl.content.cloneNode\(true\).firstElementChild;) Tj T* (  document.getElementById\('chatWindow'\).appendChild\(typing\);) Tj T*  T* (  const res = await fetch\('/chat', {) Tj T* (    method: 'POST',) Tj T* (    headers: {'Content-Type': 'application/json'},) Tj T* (    body: JSON.stringify\({ message: text, cart }\)) Tj T* (  }\);) Tj T* (  const data = await res.json\(\);) Tj T* (  typing.remove\(\);) Tj T* (  cart = data.cart || cart;) Tj T* (  appendMessage\(data.response, 'bot'\);) Tj T* (}) Tj T*  T* (renderMenu\(\);) Tj T* ET
