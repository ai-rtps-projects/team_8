BT 1 0 0 1 36 220 Tm /F4 8 Tf 12 TL (let cart = [];) Tj T*  T* (// Render menu cards from API) Tj T* (async function renderMenu\(\) {) Tj T* (  const res = await fetch\('/menu'\);) Tj T* (  const data = await res.json\(\);) Tj T* (  const container = document.getElementById\('menu-container'\);) Tj T* (  container.innerHTML = data.items.map\(item => `) Tj T* (    <div class="card">) Tj T* (      <img src="${item.img}" alt="${item.name}">) Tj T* (      <div class="card-body">) Tj T* (        <h3 class="card-title">${item.name}</h3>) Tj T* (        <div class="card-price">$${item.price.toFixed\(2\)}</div>) Tj T* (        <button class="btn") Tj T* (          onclick="addFromDashboard\('${item.id}','${item.name}',${item.price}\)">) Tj T* (          Add to Cart) Tj T* (        </button>) Tj T* (      </div>) Tj T* (    </div>) Tj T* ET
